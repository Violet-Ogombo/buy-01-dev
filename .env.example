# ================================================
# Environment Variables Example
# ================================================
# Copy this to .env and fill in your actual values
# .env file is listed in .gitignore and will NOT be committed
# ================================================

# ==================== JWT ====================
# Generated JWT Secret (use openssl rand -base64 64 | tr -d '=')
# Keep this secret and change it for production
JWT_SECRET=your-generated-jwt-secret-here

# ==================== Database ====================
# MongoDB Connection
MONGODB_URI=mongodb://mongodb:27017/buy01
MONGODB_USER=admin
MONGODB_PASSWORD=password123

# ==================== Message Broker ====================
# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ZOOKEEPER_SERVERS=zookeeper:2181

# ==================== Service Discovery ====================
# Eureka Discovery Server
EUREKA_URL=http://discovery-server:8761/eureka

# ==================== Code Quality ====================
# SonarQube (local)
SONAR_HOST_URL=http://sonarqube:9000
SONAR_LOGIN=admin
SONAR_PASSWORD=admin

# SonarCloud (for GitHub Actions)
SONAR_ORGANIZATION=violet-ogombo
//SONAR_TOKEN=your-sonarcloud-token-here

# ==================== GitHub ====================
# GitHub Token (optional, for GitHub Actions)
GITHUB_TOKEN=your-github-token-here

# ==================== SSL/TLS ====================
# Keystore Configuration
SSL_KEYSTORE_PASSWORD=password123
SSL_KEYSTORE_PATH=classpath:keystore.p12

# ==================== Notifications ====================
# Slack Webhook (for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==================== Jenkins ====================
# Jenkins Configuration (optional)
JENKINS_URL=http://jenkins:8085
JENKINS_USER=admin
JENKINS_TOKEN=your-jenkins-token-here
